@page "/settings"
@using Maui2.Models
@using Maui2.Services
@inject ConfigurationService Config
@inject RabbitMqService Rabbit

<div class="flex flex-col h-full bg-slate-100 overflow-y-auto">

    <!-- Header -->
    <div class="flex-shrink-0 bg-white border-b border-slate-200 shadow-sm">
        <div class="flex items-center h-14 px-4 gap-3">
            <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </div>
            <h2 class="text-base font-semibold text-slate-800">Configuración</h2>
        </div>
    </div>

    <!-- Content -->
    <div class="flex-1 px-4 py-5 space-y-4">

        <!-- Connection status -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 px-4 py-3 flex items-center gap-3">
            <div class="w-2.5 h-2.5 rounded-full flex-shrink-0 @(Rabbit.IsConnected ? "bg-emerald-400" : "bg-red-400") shadow-sm"></div>
            @if (Rabbit.IsConnected)
            {
                <span class="text-sm font-medium text-emerald-600">Conectado correctamente</span>
            }
            else
            {
                <div>
                    <span class="text-sm font-medium text-red-500">Sin conexión</span>
                    @if (!string.IsNullOrEmpty(Rabbit.ConnectionError))
                    {
                        <p class="text-xs text-red-400 mt-0.5">@Rabbit.ConnectionError</p>
                    }
                </div>
            }
        </div>

        <!-- RabbitMQ card -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="px-4 pt-4 pb-2 border-b border-slate-50">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">RabbitMQ</p>
            </div>

            <div class="divide-y divide-slate-50">
                <div class="px-4 py-3">
                    <label class="text-xs font-medium text-slate-400 block mb-1">Host</label>
                    <input placeholder="localhost" @bind="RabbitConfig.Host"
                           class="w-full text-sm text-slate-700 bg-transparent focus:outline-none placeholder-slate-300" />
                </div>
                <div class="px-4 py-3">
                    <label class="text-xs font-medium text-slate-400 block mb-1">Usuario</label>
                    <input placeholder="guest" @bind="RabbitConfig.Username"
                           class="w-full text-sm text-slate-700 bg-transparent focus:outline-none placeholder-slate-300" />
                </div>
                <div class="px-4 py-3">
                    <label class="text-xs font-medium text-slate-400 block mb-1">Contraseña</label>
                    <input type="password" placeholder="••••••••" @bind="RabbitConfig.Password"
                           class="w-full text-sm text-slate-700 bg-transparent focus:outline-none placeholder-slate-300" />
                </div>
            </div>
        </div>

        <!-- Queues card -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="px-4 pt-4 pb-2 border-b border-slate-50">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Colas</p>
            </div>
            <div class="divide-y divide-slate-50">
                <div class="px-4 py-3">
                    <label class="text-xs font-medium text-slate-400 block mb-1">Mi Cola</label>
                    <input placeholder="queue_b" @bind="RabbitConfig.MyQueue"
                           class="w-full text-sm text-slate-700 bg-transparent focus:outline-none placeholder-slate-300" />
                </div>
                <div class="px-4 py-3">
                    <label class="text-xs font-medium text-slate-400 block mb-1">Cola Destino</label>
                    <input placeholder="queue_a" @bind="RabbitConfig.TargetQueue"
                           class="w-full text-sm text-slate-700 bg-transparent focus:outline-none placeholder-slate-300" />
                </div>
            </div>
        </div>

        <!-- Save button -->
        <button @onclick="Save"
                class="w-full py-3.5 rounded-2xl bg-gradient-to-r from-primary-500 to-primary-700 text-white text-sm font-semibold shadow-md hover:shadow-lg active:scale-95 transition-all duration-200">
            Guardar y Reconectar
        </button>

    </div>
</div>

@code {

    RabbitSettings RabbitConfig = new();

    protected override void OnInitialized()
    {
        RabbitConfig = Config.CurrentSettings;

        Rabbit.OnConnectionStateChanged += () =>
        {
            InvokeAsync(StateHasChanged);
        };
    }

    void Save()
    {
        Config.UpdateSettings(RabbitConfig);
        Rabbit.ConnectAsync();
    }
}